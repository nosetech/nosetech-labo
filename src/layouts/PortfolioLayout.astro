---
import { Image } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import CarouselSplide from "@components/CarouselSplide.astro";
import type { ImageMetadata } from "astro";

export interface Props {
  frontmatter: {
    title: string;
    date: string;
    icon: string;
    image: string[];
    description: string;
  };
}

const { frontmatter } = Astro.props;

// src/assets配下のすべての画像をインポート
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,webp,svg}",
);

// frontmatterから受け取ったパスをもとに画像をロード
const getImage = async (imagePath: string) => {
  const fullPath = `/src/assets/${imagePath}`;
  if (fullPath in images) {
    return (await images[fullPath]()).default;
  }
  return null;
};

const iconImage = await getImage(frontmatter.icon);

// 複数の画像をロード
const productImages = await Promise.all(
  frontmatter.image.map((imagePath) => getImage(imagePath)),
);

// nullでない画像のみをフィルタリング
const validProductImages = productImages.filter(
  (img) => img !== null,
) as ImageMetadata[];
const hasMultipleImages = validProductImages.length > 1;
const productImage = validProductImages[0] || null;

// ポートフォリオページの一覧を取得
const portfolioPages = await Astro.glob("../pages/portfolio/*.mdx");
const sortedPortfolioPages = portfolioPages
  .map((module) => ({
    frontmatter: module.frontmatter,
    url: module.url || "",
  }))
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).getTime() -
      new Date(a.frontmatter.date).getTime(),
  );

// 現在のページURL
const currentPageUrl = Astro.url.pathname;
---

<Layout
  title={`${frontmatter.title} | Portfolio`}
  description={frontmatter.description}
>
  <div class="portfolio-container">
    <aside class="portfolio-nav">
      <nav class="portfolio-nav-list">
        {
          sortedPortfolioPages.map(async (page) => {
            const pageIconImage = await getImage(page.frontmatter.icon);
            const isActive = currentPageUrl === page.url;

            return (
              <a
                href={page.url}
                class={`portfolio-nav-item ${isActive ? "active" : ""}`}
                title={page.frontmatter.title}
              >
                {pageIconImage ? (
                  <Image
                    src={pageIconImage}
                    alt={page.frontmatter.title}
                    width={60}
                    height={60}
                    loading="lazy"
                  />
                ) : (
                  <img
                    src={page.frontmatter.icon}
                    alt={page.frontmatter.title}
                    width="60"
                  />
                )}
              </a>
            );
          })
        }
      </nav>
    </aside>

    <article class="news-article">
      <header class="article-header">
        <div class="news-image">
          <Image
            src={iconImage!}
            alt="news image"
            width={80}
            height={80}
            loading="lazy"
          />
        </div>
        <h1>{frontmatter.title}</h1>
      </header>
      <div class="product-image">
        {
          hasMultipleImages ? (
            <>
              <div class="splide" role="region" aria-label="Product carousel">
                <div class="splide__track">
                  <ul class="splide__list">
                    {validProductImages.map((img, index) => (
                      <li class="splide__slide">
                        <Image
                          src={img}
                          alt={`product image ${index + 1}`}
                          width={1000}
                          loading="lazy"
                        />
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="splide__arrows">
                  <button
                    class="splide__arrow splide__arrow--prev"
                    type="button"
                  >
                    <span class="sr-only">Previous slide</span>
                  </button>
                  <button
                    class="splide__arrow splide__arrow--next"
                    type="button"
                  >
                    <span class="sr-only">Next slide</span>
                  </button>
                </div>

                <ul class="splide__pagination" role="tablist" />

                <div class="carousel-thumbnails">
                  {validProductImages.map((img, index) => (
                    <div class="thumbnail" data-index={index}>
                      <Image
                        src={img}
                        alt={`Thumbnail ${index + 1}`}
                        width={100}
                        height={100}
                        loading="lazy"
                      />
                    </div>
                  ))}
                </div>
              </div>
              <CarouselSplide images={validProductImages} />
            </>
          ) : (
            <Image
              src={productImage!}
              alt="product image"
              width={1000}
              loading="lazy"
            />
          )
        }
      </div>
      <div class="article-content">
        <slot />
      </div>
    </article>
  </div>
</Layout>

<style>
  .portfolio-container {
    display: flex;
    gap: 24px;
    padding: 0 16px;
  }

  .portfolio-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    height: fit-content;
  }

  .portfolio-nav-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .portfolio-nav-item {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 90px;
    height: 90px;
    padding: 16px;
    border-radius: 6px;
    border: 1px solid;
    border-color: #a2a2a2;
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    overflow: hidden;
  }

  .portfolio-nav-item:hover {
    border-color: var(--primary-accent-color);
    transform: scale(1.05);
  }

  .portfolio-nav-item.active {
    border: 2px solid;
    border-color: var(--primary-accent-color);
    background-color: var(--primary-accent-color-alpha);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .portfolio-nav-item img,
  .portfolio-nav-item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .news-article {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .article-header {
    width: 90%;
    max-width: 800px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
  }

  .article-header h1 {
    margin: 0 0 1rem 0;
    font-size: 32px;
  }

  .news-image {
    width: 80px;
  }

  .product-image {
    width: 50%;
    margin-top: 16px;
  }

  /* Splide Carousel Styles */
  .splide {
    width: 100%;
  }

  .splide__track {
    position: relative;
    width: 100%;
    overflow: hidden;
    min-height: 400px;
  }

  .splide__list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .splide__slide {
    flex: 0 0 100%;
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .splide__slide :global(img) {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .splide__arrows {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 16px;
  }

  .splide__arrow {
    background-color: var(--primary-accent-color);
    color: white;
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: all 0.3s ease;
  }

  .splide__arrow:hover {
    transform: scale(1.1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .splide__arrow:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .splide__arrow--prev::before {
    content: "◀";
  }

  .splide__arrow--next::before {
    content: "▶";
  }

  .splide__pagination {
    display: flex;
    justify-content: center;
    gap: 8px;
    list-style: none;
    margin: 16px 0 0 0;
    padding: 0;
  }

  .splide__pagination__page {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #ccc;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .splide__pagination__page.is-active {
    background-color: var(--primary-accent-color);
    width: 24px;
    border-radius: 4px;
  }

  .carousel-thumbnails {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  .thumbnail {
    width: 80px;
    height: 80px;
    border-radius: 4px;
    overflow: hidden;
    border: 2px solid #ddd;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .thumbnail:hover {
    border-color: var(--primary-accent-color);
    transform: scale(1.05);
  }

  .thumbnail.active {
    border-color: var(--primary-accent-color);
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.2);
  }

  .thumbnail :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .article-content {
    width: 90%;
    max-width: 800px;
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .article-content a:link {
    color: var(--color-link);
    text-decoration: underline;
  }

  .article-content a:visited {
    color: var(--color-visited-link);
  }

  .article-content a:hover {
    color: var(--color-selectedlink);
  }

  .article-content a:active {
    color: var(--color-active-link);
  }

  @media (max-width: 700px) {
    .portfolio-container {
      flex-direction: column;
      gap: 16px;
    }

    .portfolio-nav {
      position: static;
      flex-direction: row;
      justify-content: center;
      padding: 16px 0;
      overflow-x: auto;
    }

    .portfolio-nav-list {
      flex-direction: row;
      gap: 12px;
    }

    .portfolio-nav-item {
      width: 60px;
      height: 60px;
    }

    .article-header {
      gap: 8px;
    }

    .article-header h1 {
      font-size: 24px;
    }

    .news-image {
      width: 60px;
    }

    .product-image {
      width: 100%;
    }

    .carousel-thumbnails {
      gap: 8px;
    }

    .thumbnail {
      width: 60px;
      height: 60px;
    }
  }
</style>
