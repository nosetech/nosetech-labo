---
import deskImage from "@assets/desk.svg";
import deskDarkImage from "@assets/desk-dark.svg";
import rightcheatIcon from "@assets/rightcheat-icon.svg";
import Title from "@components/Title.astro";
---

<div class="site-image">
  <div class="title">
    <Title />
  </div>
  <div class="desk">
    <img
      id="desk-image"
      src={deskImage.src}
      data-light-src={deskImage.src}
      data-dark-src={deskDarkImage.src}
      alt="A desk"
    />
    <a href="https://github.com/nosetech/right-cheat" target="_blank"
      ><img
        class="product-on-desk"
        src={rightcheatIcon.src}
        alt="RightCheat"
      /></a
    >
  </div>
</div>

<style>
  .site-image {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .desk {
    margin-top: 32px;
    position: relative;
    width: 100%;
    max-width: 750px;
  }

  #desk-image {
    width: 100%;
    height: auto;
    max-width: 750px;
  }

  .product-on-desk {
    position: absolute;
    top: 5%;
    left: 20%;
    transform: translate(-50%, -50%);
    width: 9.3%;
    height: auto;
  }

  @media (max-width: 767px) {
    .desk {
      margin-top: 16px;
    }

    #desk-image {
      max-width: 100%;
    }

    .product-on-desk {
      width: 10%;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    #desk-image {
      max-width: 600px;
    }
  }
</style>

<script>
  function initDeskImageTheme() {
    const deskImage = document.getElementById("desk-image") as HTMLImageElement;
    const html = document.documentElement;

    if (!deskImage) return;

    function updateDeskImage() {
      const currentTheme = html.getAttribute("data-theme") || "light";
      if (currentTheme === "dark") {
        const darkDeskSrc = deskImage.getAttribute("data-dark-src");
        if (darkDeskSrc) {
          deskImage.src = darkDeskSrc;
        }
      } else {
        // ライトテーマの場合は元のインポートされたアセットのパスを使用
        const lightDeskSrc = deskImage.getAttribute("data-light-src");
        if (lightDeskSrc) {
          deskImage.src = lightDeskSrc;
        }
      }
    }

    // 初期画像設定
    updateDeskImage();

    // テーマ変更の監視
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (
          mutation.type === "attributes" &&
          mutation.attributeName === "data-theme"
        ) {
          updateDeskImage();
        }
      });
    });

    observer.observe(html, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  }

  // DOMContentLoadedで初期化
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDeskImageTheme);
  } else {
    initDeskImageTheme();
  }
</script>
