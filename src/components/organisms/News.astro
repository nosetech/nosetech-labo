---
import DateStr from "@components/atoms/DateStr.astro";

// 最新ニュース3件を取得
const allPosts = await Astro.glob<{
  title: string;
  date: string;
  description: string;
}>("../../pages/news/posts/*.{md,mdx}");

// 日付でソート（新しい順）して最新3件を取得
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).getTime() -
      new Date(a.frontmatter.date).getTime(),
  )
  .slice(0, 3);

const maxLength = 3;
---

<div>
  <h1>News</h1>
  <ul>
    {
      latestPosts.map((post) => (
        <li>
          <a href={post.url}>
            <div class="news-item">
              <div>
                <DateStr date={post.frontmatter.date} />
              </div>
              <div>{post.frontmatter.title}</div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
  {
    latestPosts.length > maxLength && (
      <div class="all-news">
        <a href="/news">すべてのニュース</a>
      </div>
    )
  }
</div>
<style>
  h1 {
    padding: 0;
  }

  ul {
    margin-top: -8px;
    padding-left: 8px;
    line-height: 32px;
  }

  li {
    font-size: 16px;
    list-style: none;
  }

  li a {
    color: inherit;
    text-decoration: none;
  }

  li a:hover {
    text-decoration: underline;
  }

  .news-item {
    display: flex;
    gap: 8px;
  }

  .all-news {
    margin-top: -16px;
    text-align: right;
  }

  .all-news a {
    color: inherit;
    text-decoration: none;
    font-size: inherit;
  }

  .all-news a:hover {
    text-decoration: underline;
  }

  @media (max-width: 700px) {
    h1 {
      font-size: 16px;
    }

    ul {
      line-height: 24px;
    }

    li {
      font-size: 14px;
    }

    .all-news {
      font-size: 12px;
    }
  }
</style>
